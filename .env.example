# Copy this file to `.env.local` for local development.
# Never commit real API keys.
# All files are expected to be saved as UTF-8.

DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
SILICONFLOW_API_KEY=
XIAOMI_MIMO_API_KEY=
OLLAMA_API_KEY=ollama

# Optional workspace overrides.
# By default, generated artifacts stay under `local/` and should not be committed.
# RESEARCH_RUNS_ROOT=local/runs
# RESEARCH_REPORTS_ROOT=local/reports
# RESEARCH_CACHE_ROOT=local/cache
# RESEARCH_FILES_ROOT=files

# Optional Hugging Face archive settings.
# RESEARCH_RUNS_HF_REPO=Violet1307/research-runs
# RESEARCH_CACHE_HF_REPO=Violet1307/research-cache
# RESEARCH_AUTO_PUBLISH_RUNS=1
# RESEARCH_AUTO_PUSH_CACHE_SNAPSHOT=1
# `hf_sync_cli` 会优先读取上面两个 repo 配置，支持一键批量推送或回拉。
# HF_TOKEN=
