{
  "schema_name": "sparc_disagreement_annotation_v1",
  "description": "Manual annotation schema for disagreement objects used to evaluate extractor and router quality.",
  "fields": [
    {
      "name": "qid",
      "type": "string",
      "required": true,
      "description": "Unique question id."
    },
    {
      "name": "conflict_type",
      "type": "enum",
      "required": true,
      "values": [
        "answer",
        "step",
        "evidence",
        "assumption"
      ],
      "description": "Primary type of disagreement."
    },
    {
      "name": "criticality",
      "type": "integer",
      "required": true,
      "range": [
        1,
        5
      ],
      "description": "How important the disagreement is for the final answer."
    },
    {
      "name": "outcome_changing",
      "type": "boolean",
      "required": true,
      "description": "Whether resolving this disagreement is likely to change the final answer."
    },
    {
      "name": "evidence_support",
      "type": "enum",
      "required": true,
      "values": [
        "supports_a",
        "supports_b",
        "supports_neither",
        "insufficient"
      ],
      "description": "What the available evidence supports."
    },
    {
      "name": "gold_resolution",
      "type": "enum",
      "required": true,
      "values": [
        "resolve_for_a",
        "resolve_for_b",
        "abstain"
      ],
      "description": "Gold local-audit decision for this disagreement."
    },
    {
      "name": "notes",
      "type": "string",
      "required": false,
      "description": "Optional free-form annotator notes."
    }
  ]
}
